{
  "manifest_version": 3,
  "name": "ChatGPT HTTP ERROR 431 Fixer",
  "version": "1.0.2",
  "description": "A small tool that safely cleans up accumulated temporary-chat cookies to prevent recurring HTTP ERROR 431 when using ChatGPT.",
  "minimum_chrome_version": "119",
  "permissions": [
    "alarms",
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_title": "Clean conv_key_* cookies safely"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; connect-src 'none'"
  }
}
